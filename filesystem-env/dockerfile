FROM python:3.11-slim

ARG UID=1000
ARG GID=1000
ARG USERNAME=workmate

# Install common Linux tools
RUN apt-get update && apt-get install -y \
    nano \
    wget \
    curl \
    unzip \
    zip \
    tar \
    gzip \
    bzip2 \
    xz-utils \
    procps \
    htop \
    tree \
    less \
    jq \
    build-essential \
    gcc \
    g++ \
    make \
    file \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Create user
RUN groupadd -g ${GID} ${USERNAME} && \
    useradd -m -u ${UID} -g ${GID} -s /bin/bash ${USERNAME}

# Create directories
RUN mkdir -p \
    /usr-data/uploads \
    /usr-data/output \
    /scratchpad


RUN chmod 775 /usr-data/uploads && \
    chmod 777 /usr-data/output && \
    chmod 777 /scratchpad

# Common Python packages useful for AI agents
RUN pip install --no-cache-dir \
    pandas \
    numpy \
    matplotlib \
    seaborn \
    scikit-learn \
    scipy \
    python-docx \
    pymupdf \
    python-pptx \
    openpyxl \
    xlrd \
    pillow \
    pdfplumber \
    reportlab \
    docx2txt \
    beautifulsoup4 \
    lxml \
    markdown \
    pyyaml \
    chardet \
    tabulate

USER ${USERNAME}

WORKDIR /scratchpad

CMD ["sleep", "infinity"]